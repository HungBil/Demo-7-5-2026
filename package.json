{
  "name": "bqp-demo",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "typecheck": "tsc --noEmit",
    "crawl": "tsx --tsconfig tsconfig.scripts.json scripts/crawl-bqp.ts",
